auto-install-peers=true
strict-peer-dependencies=false

# Block packages published less than 7 days ago (supply chain protection)
min-release-age=7

# Block dependency install/lifecycle scripts (supply chain protection).
# Only packages in pnpm.onlyBuiltDependencies are allowed to run
# preinstall/install/postinstall hooks during pnpm install.
# Project scripts (build, test, etc.) are not affected.
ignore-scripts=false

# Publishing: Trusted Publisher (OIDC) + Staged Publishing.
# No long-lived NPM_TOKEN needed. CI stages packages via `npm stage publish`;
# maintainer approves with 2FA at npmjs.com before they go live.
# Requires: Trusted Publisher configured per-package on npmjs.com,
# 2FA enabled on the @gpc-cli npm org.
