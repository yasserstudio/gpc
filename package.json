{
  "name": "gpc-monorepo",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:e2e": "turbo run test --filter=e2e",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "release-staged": "turbo run build && node scripts/stage-publish.js",
    "build:binary": "tsx scripts/build-binary.ts",
    "bench": "tsx scripts/benchmarks/startup.bench.ts && tsx scripts/benchmarks/command-latency.bench.ts",
    "license:check": "tsx scripts/check-licenses.ts",
    "audit": "pnpm audit --prod --audit-level=high",
    "audit:all": "pnpm audit --audit-level=moderate",
    "security:check": "pnpm audit --prod --audit-level=high && pnpm license:check",
    "security:deep": "npx deepsec scan && npx deepsec process && npx deepsec revalidate && npx deepsec export --format md-dir --out ./deepsec-findings"
  },
  "prettier": {
    "semi": true,
    "singleQuote": false,
    "trailingComma": "all",
    "tabWidth": 2,
    "printWidth": 100
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "turbo",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "prettier": "^3.9.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "turbo": "^2.10.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite": "~7.3.3",
    "vitest": "^4.1.9"
  }
}
