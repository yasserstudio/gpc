{
  "name": "gpc-monorepo",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:e2e": "turbo run test --filter=e2e",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "build:binary": "tsx scripts/build-binary.ts",
    "bench": "tsx scripts/benchmarks/startup.bench.ts && tsx scripts/benchmarks/command-latency.bench.ts",
    "license:check": "tsx scripts/check-licenses.ts",
    "audit": "pnpm audit --prod --audit-level=high",
    "audit:all": "pnpm audit --audit-level=moderate",
    "security:check": "pnpm audit --prod --audit-level=high && pnpm license:check"
  },
  "prettier": {
    "semi": true,
    "singleQuote": false,
    "trailingComma": "all",
    "tabWidth": 2,
    "printWidth": 100
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "esbuild": "^0.27.7",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  }
}
