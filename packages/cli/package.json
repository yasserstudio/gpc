{
  "name": "@gpc-cli/cli",
  "version": "0.9.35",
  "description": "GPC — Google Play Console CLI. 187 API endpoints, one tool.",
  "type": "module",
  "bin": {
    "gpc": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@gpc-cli/api": "workspace:*",
    "@gpc-cli/auth": "workspace:^",
    "@gpc-cli/config": "workspace:*",
    "@gpc-cli/core": "workspace:*",
    "@gpc-cli/plugin-sdk": "workspace:*",
    "commander": "^14.0.3"
  },
  "keywords": [
    "google-play",
    "google-play-console",
    "google-play-console-cli",
    "cli",
    "android",
    "play-store",
    "play-console",
    "fastlane-alternative",
    "release-automation",
    "devops",
    "ci-cd"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.3.5"
  }
}
