{
  "name": "@gpc-cli/plugin-sdk",
  "version": "0.9.10",
  "description": "Plugin SDK for extending GPC Google Play Console CLI. Lifecycle hooks, custom commands, and permissions.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "homepage": "https://yasserstudio.github.io/gpc/",
  "keywords": [
    "google-play",
    "google-play-console",
    "plugin",
    "sdk",
    "lifecycle-hooks",
    "extensible",
    "play-store"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yasserstudio/gpc"
  }
}
