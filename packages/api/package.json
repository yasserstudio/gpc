{
  "name": "@gpc/api",
  "version": "0.0.0",
  "description": "Typed client for Google Play Developer API v3",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@gpc/auth": "workspace:*"
  },
  "keywords": ["google-play", "api", "android-publisher"],
  "license": "MIT"
}
