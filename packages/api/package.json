{
  "name": "@gpc-cli/api",
  "version": "1.0.37",
  "description": "TypeScript client for all 217 Google Play Developer API v3 endpoints. Typed requests and responses, rate limiting, edit lifecycle management.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@gpc-cli/auth": "workspace:*"
  },
  "homepage": "https://yasserstudio.github.io/gpc/",
  "keywords": [
    "google-play",
    "google-play-console",
    "google-play-api",
    "android-publisher",
    "play-developer-api",
    "android",
    "typescript",
    "sdk",
    "play-store",
    "api-client"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.6.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yasserstudio/gpc"
  }
}
