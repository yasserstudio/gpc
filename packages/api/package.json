{
  "name": "@gpc-cli/api",
  "version": "1.0.29",
  "description": "Typed client for Google Play Developer API v3",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@gpc-cli/auth": "workspace:*"
  },
  "keywords": [
    "google-play",
    "google-play-console",
    "api",
    "android-publisher"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.5.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yasserstudio/gpc"
  }
}
