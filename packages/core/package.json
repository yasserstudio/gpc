{
  "name": "@gpc-cli/core",
  "version": "0.9.25",
  "description": "Business logic and command orchestration for GPC",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@gpc-cli/api": "workspace:*",
    "@gpc-cli/auth": "workspace:*",
    "@gpc-cli/config": "workspace:*",
    "@gpc-cli/plugin-sdk": "workspace:*"
  },
  "keywords": [
    "google-play",
    "core"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.5.0"
  }
}
