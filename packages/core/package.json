{
  "name": "@gpc-cli/core",
  "version": "0.9.60",
  "description": "Core business logic for GPC — Google Play Console CLI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/google": "^2.0.0",
    "@ai-sdk/openai": "^2.0.0",
    "@gpc-cli/api": "workspace:*",
    "@gpc-cli/auth": "workspace:*",
    "@gpc-cli/config": "workspace:*",
    "@gpc-cli/plugin-sdk": "workspace:*",
    "ai": "^5.0.0",
    "protobufjs": "^8.0.1",
    "yauzl": "^3.3.0"
  },
  "keywords": [
    "google-play",
    "google-play-console",
    "core"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/yauzl": "^2.10.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yasserstudio/gpc"
  }
}
