{
  "name": "@gpc-cli/core",
  "version": "0.9.74",
  "description": "Core business logic for GPC. Releases, rollouts, vitals, preflight scanner, AI changelog, metadata sync for Google Play Developer API.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/google": "^3.0.0",
    "@ai-sdk/openai": "^3.0.0",
    "@gpc-cli/api": "workspace:*",
    "@gpc-cli/auth": "workspace:*",
    "@gpc-cli/config": "workspace:*",
    "@gpc-cli/plugin-sdk": "workspace:*",
    "ai": "^6.0.0",
    "protobufjs": "^8.6.0",
    "yauzl": "^3.3.2"
  },
  "homepage": "https://yasserstudio.github.io/gpc/",
  "keywords": [
    "google-play",
    "google-play-console",
    "google-play-api",
    "android-publisher",
    "play-developer-api",
    "releases",
    "rollouts",
    "vitals",
    "preflight",
    "changelog",
    "metadata",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/yauzl": "^2.10.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yasserstudio/gpc"
  }
}
