{
  "name": "@gpc-cli/auth",
  "version": "0.9.12",
  "description": "Authentication strategies for Google Play Developer API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "google-play",
    "google-play-console",
    "auth",
    "service-account"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.5.2"
  },
  "dependencies": {
    "google-auth-library": "^10.6.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yasserstudio/gpc"
  }
}
