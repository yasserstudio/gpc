{
  "name": "@gpc-cli/auth",
  "version": "0.9.16",
  "description": "Google Play API authentication for Node.js. Service account, OAuth 2.0, and Application Default Credentials.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "homepage": "https://yasserstudio.github.io/gpc/",
  "keywords": [
    "google-play",
    "google-play-console",
    "android",
    "auth",
    "service-account",
    "oauth",
    "google-auth",
    "play-store",
    "application-default-credentials"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.9.1"
  },
  "dependencies": {
    "google-auth-library": "^10.7.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yasserstudio/gpc"
  }
}
