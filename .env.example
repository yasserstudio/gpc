# GPC — Environment Variables
# Copy to .env and fill in your values.
# See: https://yasserstudio.github.io/gpc/reference/environment-variables

# Authentication (pick one)
GPC_SERVICE_ACCOUNT=          # Path to service account JSON, or inline JSON string
# GPC_PROFILE=                # Named auth profile (from gpc auth profiles)

# App
GPC_APP=                      # Default package name (e.g. com.example.myapp)

# Output
# GPC_OUTPUT=table            # Default: table (TTY) / json (piped). Options: table, json, yaml, markdown
# GPC_NO_COLOR=1              # Disable color output
# GPC_NO_INTERACTIVE=1        # Disable interactive prompts (auto-set in CI)

# Network
# GPC_MAX_RETRIES=3           # Max retry attempts for failed requests
# GPC_TIMEOUT=30000           # Request timeout in milliseconds

# Debug
# GPC_DEBUG=1                 # Enable verbose debug output
