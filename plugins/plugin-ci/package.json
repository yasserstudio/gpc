{
  "name": "@gpc-cli/plugin-ci",
  "version": "0.1.2",
  "description": "CI/CD helpers for GPC",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@gpc-cli/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.3.5"
  },
  "keywords": [
    "google-play",
    "ci",
    "plugin"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
